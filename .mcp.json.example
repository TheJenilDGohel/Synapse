{
  "mcpServers": {
    "synapse": {
      "command": "npx",
      "args": [
        "-y",
        "synapse"
      ],
      "env": {
        "MCP_MODE": "stdio",
        "SYNAPSE_CONFIG": "/Users/you/.synapse/synapse.config.json",
        "SYNAPSE_INDEX_BACKEND": "sqlite-vec",
        "SYNAPSE_DB_PATH": "/Users/you/.synapse/synapse.db",
        "SYNAPSE_INDEX_PATH": "/Users/you/.synapse/synapse.index.json"
      }
    }
  }
}
