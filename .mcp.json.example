{
  "mcpServers": {
    "loci": {
      "command": "npx",
      "args": [
        "-y",
        "loci"
      ],
      "env": {
        "MCP_MODE": "stdio",
        "LOCI_CONFIG": "/Users/you/.loci/loci.config.json",
        "LOCI_INDEX_BACKEND": "sqlite-vec",
        "LOCI_DB_PATH": "/Users/you/.loci/loci.db",
        "LOCI_INDEX_PATH": "/Users/you/.loci/loci.index.json"
      }
    }
  }
}
