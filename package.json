{
  "name": "synapse-cortex",
  "version": "0.0.1-beta.3",
  "license": "MIT",
  "author": "Jenil",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "synapse",
    "ai",
    "agents",
    "knowledge-graph",
    "memory",
    "code-search",
    "code-intelligence",
    "sqlite",
    "local-first",
    "embeddings",
    "semantic-search",
    "ai-memory",
    "code-assistant",
    "temporal-graph",
    "offline-ai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "The only MCP server combining semantic code search, temporal knowledge graph, and persistent AI memory. 74 tools, zero cloud, pure SQLite. Alternative to Mem0, GitNexus, Graphiti.",
  "bin": {
    "synapse": "bin/synapse.cjs",
    "synapse-upgrade": "bin/synapse-upgrade.cjs",
    "synapse-setup": "bin/synapse-setup.cjs",
    "synapse-doctor": "bin/synapse-doctor.cjs",
    "synapse-install-skill": "bin/synapse-install-skill.cjs",
    "synapse-task-context": "bin/synapse-task-context.cjs",
    "synapse-capture-outcome": "bin/synapse-capture-outcome.cjs"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "skills",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "node -e \"try{require('child_process').execSync('node scripts/runtime/install-synapse-skill.mjs --quiet',{stdio:'ignore'})}catch(e){}\"",
    "setup": "tsx scripts/runtime/setup-synapse.mjs",
    "upgrade": "tsx scripts/runtime/upgrade-synapse.mjs",
    "doctor": "tsx scripts/runtime/doctor-synapse.mjs",
    "install:skill": "node scripts/runtime/install-synapse-skill.mjs",
    "task-context": "node scripts/memory/task-context-synapse.mjs",
    "capture-outcome": "node scripts/memory/capture-outcome-synapse.mjs",
    "start": "tsx src/interfaces/app/mcp-server.ts",
    "stress:synapse": "node scripts/quality/stress-synapse.mjs",
    "test": "tsx --test",
    "test:coverage": "node --import tsx/esm --test --experimental-test-coverage",
    "lint": "eslint . --max-warnings=0",
    "quality:cycles": "madge --circular --extensions js,mjs,ts src",
    "quality:deps": "depcheck --json --ignores=publint,@huggingface/transformers,tree-sitter-*,ripgrep-bin",
    "quality:package": "node scripts/quality/quality-package.mjs",
    "quality:audit": "node scripts/quality/quality-audit.mjs",
    "quality": "npm run check && npm run lint && npm run test:coverage && npm run quality:cycles && npm run quality:deps && npm run quality:package && npm run quality:audit",
    "release:check": "tsx scripts/release/release-exit-criteria.mjs",
    "check": "tsc --noEmit && node -e \"const { execSync } = require('child_process'); const { readdirSync } = require('fs'); const { join } = require('path'); ['bin', 'scripts'].forEach(d => { try { readdirSync(d, { recursive: true }).forEach(f => { if (f.endsWith('.js') || f.endsWith('.cjs') || f.endsWith('.mjs')) { execSync('node --check ' + join(d, f), { stdio: 'inherit' }); } }); } catch (e) {} });\"",
    "build": "tsc",
    "build:check": "tsc --noEmit",
    "prepublishOnly": "npm run check",
    "release:beta": "npm publish --tag beta",
    "release:latest": "npm publish",
    "docs:dev": "cd docs && jaspr serve",
    "docs:build": "cd docs && jaspr build --dart-define=SITE_BASE_PATH=/Synapse",
    "docs:preview": "cd docs && jaspr serve --release",
    "docs:deploy": "npm run docs:build && firebase deploy --only hosting",
    "bump:beta": "npm version prerelease --preid=beta --no-git-tag-version"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/ripgrep": "^1.17.1",
    "ora": "^9.3.0",
    "sqlite-vec": "^0.1.9",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "tree-sitter": "^0.21.1",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-lua": "^0.21.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@huggingface/transformers": "^4.2.0",
    "@types/node": "^25.5.2",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "madge": "^8.0.0",
    "publint": "^0.3.18",
    "typescript": "^6.0.2"
  }
}
